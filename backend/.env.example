# Copy to backend/.env and fill in values for local dev.

# Database
DB_URL=jdbc:postgresql://localhost:5432/hotel_pms
DB_USERNAME=postgres
DB_PASSWORD=

# Redis (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — JWT_SECRET must be >= 32 bytes. Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_ISSUER=hotel-pms
JWT_ACCESS_TTL=15
JWT_REFRESH_TTL=7

# Seed admin (used only on first startup)
ADMIN_EMAIL=admin@hotel.local
ADMIN_INITIAL_PASSWORD=
